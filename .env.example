# Test Database Configuration
# Sqlite Database URL
TEST_DATABASE_URL=file:test.db

# Encryption key for password hashing, DO NOT LOSE THIS
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-encryption-key-here

# OAuth Configuration
# GitHub OAuth (if using GitHub authentication)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email Configuration
PLUNK_BASE_URL="https://next-api.useplunk.com"
PLUNK_SECRET_KEY=your-plunk-secret-key
EMAIL_VERIFICATION_TIMEOUT_MINUTES=email-timeout-in-minutes
