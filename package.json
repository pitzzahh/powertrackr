{
  "name": "powertrackr",
  "version": "1.6.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "build:preview": "npm run build && npm run preview",
    "prepare": "svelte-kit sync || echo ''",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || echo 'Git hooks setup skipped'",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint .",
    "format": "prettier --write .",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate && tsx scripts/flatten-migrations.ts",
    "db:flatten-migrations": "tsx scripts/flatten-migrations.ts",
    "db:migrate": "drizzle-kit migrate && tsx scripts/flatten-migrations.ts && wrangler d1 migrations apply powertrackr-db",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "cf:types": "wrangler types && mv worker-configuration.d.ts src/"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "@noble/hashes": "^2.0.1",
    "@oslojs/binary": "^1.0.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@oslojs/otp": "^1.1.0",
    "@pilcrowjs/object-parser": "^0.0.4",
    "arctic": "^3.7.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "dotenv": "^17.3.1",
    "gsap": "^3.14.2",
    "mode-watcher": "^1.1.0",
    "runed": "^0.37.1",
    "svelte-toolbelt": "^0.10.6",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@lucide/svelte": "^0.577.0",
    "@number-flow/svelte": "^0.4.0",
    "@prettier/plugin-oxc": "^0.1.3",
    "@svelte-put/qr": "^2.1.2",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/enhanced-img": "^0.10.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/table-core": "^8.21.3",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "drizzle-kit": "^1.0.0-beta.16-ea816b6",
    "drizzle-orm": "^1.0.0-beta.16-ea816b6",
    "layerchart": "2.0.0-next.46",
    "oxlint": "^1.56.0",
    "phosphor-svelte": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.5",
    "svelte-render-scan": "^1.1.0",
    "svelte-seo": "^2.0.0",
    "svelte-sonner": "^1.1.0",
    "sveltekit-sse": "^0.14.3",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ],
    "ignoredBuiltDependencies": [
      "sharp"
    ]
  }
}
